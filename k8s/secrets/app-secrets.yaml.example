# Copy to app-secrets.yaml and fill in real values (do not commit the real file)
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: microservices-demo
type: Opaque
stringData:
  JWT_SECRET: "your-super-secret-jwt-key-change-in-production-min-32-chars"
  AUTH_DATABASE_URL: "postgresql://postgres:postgres@auth-db:5432/auth_db"
  USER_DATABASE_URL: "postgresql://postgres:postgres@user-db:5432/user_db"
  TASK_DATABASE_URL: "postgresql://postgres:postgres@task-db:5432/task_db"
  NOTIFICATION_DATABASE_URL: "postgresql://postgres:postgres@notification-db:5432/notification_db"
